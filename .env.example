# CCAE跨文化适配引擎 - 环境变量配置模板
# 复制此文件为 .env 并修改相应的值

# ==================== 安全配置 ====================
# Flask密钥（必须修改！生产环境必须使用强随机密钥）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
CCAE_SECRET_KEY=your-secret-key-here-change-in-production

# ==================== 数据库配置 ====================
# SQLite数据库路径（默认使用相对路径 data/ccae.db）
# DATABASE_PATH=data/ccae.db

# ==================== API配置 ====================
# API监听地址（生产环境建议使用 0.0.0.0）
# API_HOST=0.0.0.0

# API端口
# API_PORT=5000

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# 日志文件路径
# LOG_FILE=logs/ccae.log

# ==================== 功能开关 ====================
# 是否启用调试模式（生产环境必须关闭）
# DEBUG=False

# 是否启用CORS（跨域资源共享）
# CORS_ENABLED=True

# ==================== 第三方服务配置 ====================
# 翻译服务API密钥（如使用第三方翻译服务）
# TRANSLATE_API_KEY=your-translate-api-key

# 视觉识别模型路径（如使用本地模型）
# VISION_MODEL_PATH=models/vision_model

# ==================== 其他配置 ====================
# 上传文件最大大小（字节）
# MAX_UPLOAD_SIZE=10485760

# 临时文件目录
# TEMP_DIR=temp
